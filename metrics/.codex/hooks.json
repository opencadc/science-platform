{
  "version": "2.0",
  "source": "docs/harness/hook-policy.yaml",
  "bridge": "python -m harness.hooks.bridge",
  "tool": "codex",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --group harness python -m harness.hooks.bridge session_start --tool codex",
            "statusMessage": "Loading harness context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --group harness python -m harness.hooks.bridge shell_command_start --tool codex",
            "statusMessage": "Running harness command policy checks"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --group harness python -m harness.hooks.bridge pre_file_write --tool codex",
            "statusMessage": "Running harness write policy checks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --group harness python -m harness.hooks.bridge post_task_complete --tool codex",
            "statusMessage": "Applying harness verification guidance"
          }
        ]
      }
    ]
  }
}
