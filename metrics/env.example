# Optional template for local tooling that reads a `.env` file (for example
# legacy `docker compose` in this directory). The supported dev contract is
# Kubernetes-first; see `docs/dev-setup.md` and `docs/environment-contracts.md`.
#
# Copy to `.env` under `metrics/` if your workflow expects it.
#
# Nested settings use METRICS_ + __ (see `docs/environment-contracts.md`).

METRICS_CACHE__BACKEND=redis
METRICS_REDIS_URL=redis://redis:6379/0
# One of: dev | integration | staging | production (aliases int, prod accepted)
METRICS_ENVIRONMENT=dev
#
# Kueue (JSON array of queue names, not a comma-separated string):
# METRICS_PROVIDERS__KUEUE__CLUSTER_QUEUES='["cq-proton","cq-neutron","cq-electron"]'
# METRICS_PROVIDERS__KUEUE__COHORT=cohort-atom
# METRICS_PROVIDERS__KUEUE__KUBE_API_URL=https://kubernetes.default.svc
#
# Optional: platform scope TTL (JSON object):
# METRICS_CACHE__SCOPE_TTL_SECONDS='{"platform":300}'
#
# METRICS_CONFIG_FILE=/path/to/config.yaml
# METRICS_REQUIRE_CONFIG_FILE=false
#
# Default YAML path in containers: /etc/canfar/metrics/config.yaml
# (see `docs/examples/metrics.config.yaml`).
