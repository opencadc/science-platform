# Optional template for Docker Compose variable substitution.
# Copy to `.env` in this directory (`metrics/`). Compose loads `.env` automatically.
#
# The service composes platform metrics from Kueue plus Prometheus (see
# docs/plans/PLAN_M3_app_structure_and_platform_sources.md). For local Compose,
# point URLs at reachable endpoints or use Minikube + Helm instead.
METRICS_CACHE_BACKEND=redis
METRICS_REDIS_URL=redis://redis:6379/0
# One of: dev | integration | staging | production (aliases int, prod accepted)
METRICS_ENVIRONMENT=dev
# Required for startup validation and usage queries:
# METRICS_PLATFORM__PROMETHEUS__URL=http://prometheus.monitoring.svc:9090
# Legacy alias still merged at runtime:
# METRICS_PROMETHEUS_URL=http://prometheus.monitoring.svc:9090
# METRICS_PLATFORM__KUEUE__KUBE_API_URL=https://kubernetes.default.svc
# METRICS_KUEUE_CLUSTER_QUEUES=cq-proton,cq-neutron,cq-electron
# METRICS_KUEUE_COHORT=cohort-atom
# METRICS_CACHE_TTL_SECONDS=300
