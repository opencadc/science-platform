# Cursor and IDE runtime state - not part of the harness contract
.cursor/hooks/state/
.cursor/hooks/state/**
.cursor/.runtime/
.codex/.runtime/
.claude/.runtime/

# Legacy packaged Helm subchart tarballs (file:// deps), if reintroduced
helm/metrics-api/charts/*.tgz
